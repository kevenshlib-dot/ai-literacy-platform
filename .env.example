# Application
APP_NAME=AI素养评测平台
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key
API_V1_PREFIX=/api/v1
APP_TIMEZONE=Asia/Shanghai

# PostgreSQL
TESTING=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ai_literacy
POSTGRES_PASSWORD=ai_literacy_pass
POSTGRES_DB=ai_literacy_db
# Pytest loads .env.test before app settings. Leave these unset to inherit POSTGRES_* values.
# Optional test DB overrides.
# TEST_POSTGRES_HOST=
# TEST_POSTGRES_PORT=
# TEST_POSTGRES_USER=
# TEST_POSTGRES_PASSWORD=
TEST_POSTGRES_DB=ai_literacy_test

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# MinIO
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-literacy

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Redis (Celery broker)
REDIS_HOST=localhost
REDIS_PORT=6379

# LLM
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-reasoner
GEMINI_API_KEY=
GEMINI_BASE_URL=http://45.79.30.81:8089/v1beta/openai
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VOLCES_API_KEY=
VOLCES_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LOCAL_QWEN_API_KEY=token-not-needed
LOCAL_QWEN_BASE_URL=http://100.64.0.6:8100/v1

# JWT
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
