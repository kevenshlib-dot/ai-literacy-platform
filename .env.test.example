# Test overrides loaded by pytest from .env.test when the file exists.
# TESTING is forced to true by tests/conftest.py.
TESTING=true

# Optional test DB overrides. Leave unset to inherit POSTGRES_* values from .env or the shell.
# TEST_POSTGRES_HOST=100.64.0.6
# TEST_POSTGRES_PORT=5432
# TEST_POSTGRES_USER=ai_literacy
# TEST_POSTGRES_PASSWORD=ai_literacy_pass
TEST_POSTGRES_DB=ai_literacy_test
